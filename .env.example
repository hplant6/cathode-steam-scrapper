# SteamGridDB API key — get one at https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=6cc0b1865db82295fbbbb12ceac8e0d2

# Backend port (default 5174). Vite dev server runs on 5173 and proxies /api to this.
PORT=5174

# GitHub personal access token for bug reporting (needs Issues: write permission on the repo)
GITHUB_TOKEN=

# Google reCAPTCHA v2 — register at https://www.google.com/recaptcha/admin/create
# Site key is public (used in the browser); secret key stays server-side only.
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
